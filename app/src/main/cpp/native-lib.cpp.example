#include <jni.h>
#include <string>
#include <android/log.h>
#define LOG_TAG "JNI_KEYS"
#define LOGI(...) __android_log_print(ANDROID_LOG_INFO, LOG_TAG, __VA_ARGS__)


// ================== Development Constants ================== //
// #if IS_DEVELOPMENT
const char* M_ENCRYPTED_PASS_KEY = "dummy_encrypted_pass";
const char* M_ABHA_CLIENT_SECRET = "dummy_abha_secret";
const char* M_ABHA_CLIENT_ID = "dummy_abha_id";
const char* M_BASE_TMC_URL = "tmc_url";
const char* M_BASE_AMRIT_URL = "amrit_url";
const char* M_BASE_FLW_URL = "flw_url";
const char* M_BASE_ABHA_URL = "abha_url";
const char* M_ABHA_TOKEN_URL = "amrit_token_url";
const char* M_ABHA_AUTH_URL = "amrit_auth_url";
const char* M_SANJEEVANI_API_URL = "sanjeevani_url";
