<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_home"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="org.piramalswasthya.cho.ui.home.HomeFragment"
        android:label="HomeFragment" >
        <action
            android:id="@+id/action_homeFragment_to_registerPatientFragment"
            app:destination="@id/registerPatientFragment" />
    </fragment>
    <fragment
        android:id="@+id/registerPatientFragment"
        android:name="org.piramalswasthya.cho.ui.register_patient_activity.RegisterPatientFragment"
        android:label="RegisterPatientFragment" >
        <action
            android:id="@+id/action_registerPatientFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/beneficiaryCardFragment"
        android:name="org.piramalswasthya.cho.ui.beneficiary_card.BeneficiaryCardFragment"
        android:label="BeneficiaryCardFragment" >
        <argument
            android:name="patientInfo"
            app:argType="org.piramalswasthya.cho.model.PatientDisplayWithVisitInfo" />
    </fragment>
    <fragment
        android:id="@+id/personalDetailsFragment"
        android:name="org.piramalswasthya.cho.ui.commons.personal_details.PersonalDetailsFragment"
        android:label="PersonalDetailsFragment">

        <action
            android:id="@+id/action_personalDetailsFragment_to_patientDetailsFragment"
            app:destination="@id/patientDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/patientDetailsFragment"
        android:name="org.piramalswasthya.cho.ui.register_patient_activity.patient_details.PatientDetailsFragment"
        android:label="PatientDetailsFragment">

        <argument
            android:name="IS_EDIT_PATIENT"
            app:argType="boolean"
            android:defaultValue="false" />

        <argument
            android:name="PATIENT_ID"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/pncMotherListFragment"
        android:name="org.piramalswasthya.cho.ui.home.rmncha.maternal_health.PNCMotherListFragment"
        android:label="@string/pnc_mother_list" />

</navigation>