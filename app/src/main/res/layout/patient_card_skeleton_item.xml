<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_normal"
        android:layout_marginHorizontal="@dimen/margin_big"
        android:layout_marginVertical="@dimen/custom_ui_margin"
        android:elevation="@dimen/padding_normal"
        app:cardCornerRadius="@dimen/padding_normal"
        app:cardElevation="@dimen/padding_normal">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_skeleton_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/default_button"
                android:padding="@dimen/_5sdp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:id="@+id/skeleton_name_wrapper"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toStartOf="@+id/skeleton_sync_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_skeleton_header_circle" />

                    <View
                        android:layout_width="120dp"
                        android:layout_height="@dimen/_14sdp"
                        android:layout_gravity="center"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:background="@drawable/bg_skeleton_header_block" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/skeleton_sync_icon"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:background="@drawable/bg_skeleton_header_circle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/skeleton_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/padding_big"
                android:paddingTop="@dimen/_5sdp"
                android:paddingEnd="@dimen/padding_big"
                android:paddingBottom="@dimen/padding_big"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_skeleton_sync">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/ll_skeleton_age"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toStartOf="@+id/ll_skeleton_gender"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical">

                            <View
                                android:layout_width="48dp"
                                android:layout_height="15sp"
                                android:background="@drawable/bg_skeleton_block" />

                            <View
                                android:layout_width="82dp"
                                android:layout_height="17sp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_skeleton_block" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_skeleton_gender"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ll_skeleton_age"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:orientation="vertical">

                            <View
                                android:layout_width="58dp"
                                android:layout_height="15sp"
                                android:background="@drawable/bg_skeleton_block" />

                            <View
                                android:layout_width="78dp"
                                android:layout_height="17sp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_skeleton_block" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_skeleton_ben_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="12dp"
                        app:layout_constraintEnd_toStartOf="@+id/ll_skeleton_phone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ll_skeleton_age">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:orientation="vertical">

                            <View
                                android:layout_width="90dp"
                                android:layout_height="15sp"
                                android:background="@drawable/bg_skeleton_block" />

                            <View
                                android:layout_width="120dp"
                                android:layout_height="17sp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_skeleton_block" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_skeleton_phone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="12dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ll_skeleton_ben_id"
                        app:layout_constraintTop_toTopOf="@+id/ll_skeleton_ben_id">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:orientation="vertical">

                            <View
                                android:layout_width="72dp"
                                android:layout_height="15sp"
                                android:background="@drawable/bg_skeleton_block" />

                            <View
                                android:layout_width="92dp"
                                android:layout_height="17sp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_skeleton_block" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_skeleton_village"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="12dp"
                        app:layout_constraintEnd_toStartOf="@+id/ll_skeleton_visit_date"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ll_skeleton_phone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:orientation="vertical">

                            <View
                                android:layout_width="90dp"
                                android:layout_height="15sp"
                                android:background="@drawable/bg_skeleton_block" />

                            <View
                                android:layout_width="132dp"
                                android:layout_height="17sp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_skeleton_block" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_skeleton_visit_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="12dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ll_skeleton_village"
                        app:layout_constraintTop_toTopOf="@+id/ll_skeleton_village">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:orientation="vertical">

                            <View
                                android:layout_width="72dp"
                                android:layout_height="15sp"
                                android:background="@drawable/bg_skeleton_block" />

                            <View
                                android:layout_width="100dp"
                                android:layout_height="17sp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_skeleton_block" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:id="@+id/ll_skeleton_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="88dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_skeleton_action_success" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="130dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_skeleton_action_primary" />
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>
