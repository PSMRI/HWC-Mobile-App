<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="org.piramalswasthya.cho.ui.ophthalmic_screening.OphthalmicScreeningViewModel" />
        <import type="android.view.View"/>
    </data>

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_patient_information"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_normal"
                android:backgroundTint="?attr/colorPrimary"
                android:elevation="@dimen/padding_normal"
                app:cardCornerRadius="@dimen/padding_normal"
                app:cardElevation="@dimen/padding_normal"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_ben_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="@dimen/padding_normal"
                        android:text="@{viewModel.benName}"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@android:color/white"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/tv_age_gender"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Name" />

                    <TextView
                        android:id="@+id/tv_age_gender"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="@dimen/padding_normal"
                        android:text="@{viewModel.benAgeGender}"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@android:color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:text="36 Years | Male" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/ll_screening_module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ophthalmic_screening_section_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ophthalmic_is_diabetic"
                    android:textColor="@color/black"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/rg_is_diabetic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/rb_diabetic_yes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/yes"
                        android:onClick="@{() -> viewModel.setDiabeticStatus(true)}"
                        android:layout_marginEnd="16dp"/>

                    <RadioButton
                        android:id="@+id/rb_diabetic_no"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no"
                        android:onClick="@{() -> viewModel.setDiabeticStatus(false)}"/>
                </RadioGroup>

                <LinearLayout
                    android:id="@+id/ll_screening_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_screening_performed"
                        android:textColor="@color/black"
                        android:layout_marginBottom="8dp"/>

                    <RadioGroup
                        android:id="@+id/rg_screening_performed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <RadioButton
                            android:id="@+id/rb_screening_yes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/yes"
                            android:onClick="@{() -> viewModel.setScreeningPerformed(true)}"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_screening_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no"
                            android:onClick="@{() -> viewModel.setScreeningPerformed(false)}"/>
                    </RadioGroup>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_chart_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_chart_used"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_chart_used"
                            android:inputType="none"
                            android:text="@{viewModel.chartUsed}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_dist_va_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_dist_va_right"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_dist_va_right"
                            android:inputType="none"
                            android:text="@{viewModel.distVARight}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_dist_va_left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_dist_va_left"
                            android:inputType="none"
                            android:text="@{viewModel.distVALeft}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_near_va_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_near_va"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_near_va"
                            android:inputType="none"
                            android:text="@{viewModel.nearVA}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_visual_impairment_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ophthalmic_visual_impairment_alert"
                android:textColor="@color/color_error_text"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="@color/color_error_bg"
                android:visibility="@{viewModel.showVisualImpairmentAlert ? View.VISIBLE : View.GONE}"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:id="@+id/ll_case_id_module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="@{viewModel.showCaseIdSection ? View.VISIBLE : View.GONE}">

                <TextView
                    android:id="@+id/tv_case_id_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{viewModel.isCaseIdMandatory ? @string/ophthalmic_case_id_conditions_mandatory : @string/ophthalmic_case_id_conditions}"
                    android:textColor="@color/black"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/tv_case_id_selection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/select_conditions"
                        android:inputType="none"
                        android:focusable="true"
                        android:clickable="true" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Condition sub-fields — shown/hidden by Fragment observers -->
            <LinearLayout
                android:id="@+id/ll_condition_subfields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="@{viewModel.showCaseIdSection ? View.VISIBLE : View.GONE}">

                <!-- Cataract -->
                <LinearLayout
                    android:id="@+id/ll_cataract_subfield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_cataract_symptoms"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <RadioGroup
                        android:id="@+id/rg_cataract_symptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <RadioButton
                            android:id="@+id/rb_cataract_yes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/yes"
                            android:layout_marginEnd="16dp" />

                        <RadioButton
                            android:id="@+id/rb_cataract_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_cataract_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_alert_ophthalmologist_referral"
                        android:textColor="@color/color_error_text"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:background="@color/color_error_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>

                <!-- Glaucoma -->
                <LinearLayout
                    android:id="@+id/ll_glaucoma_subfield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_glaucoma_symptoms"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <RadioGroup
                        android:id="@+id/rg_glaucoma_symptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <RadioButton
                            android:id="@+id/rb_glaucoma_yes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/yes"
                            android:layout_marginEnd="16dp" />

                        <RadioButton
                            android:id="@+id/rb_glaucoma_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_glaucoma_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_alert_ophthalmologist_referral"
                        android:textColor="@color/color_error_text"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:background="@color/color_error_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>

                <!-- Diabetic retinopathy -->
                <LinearLayout
                    android:id="@+id/ll_dr_subfield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_dr_symptoms"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <RadioGroup
                        android:id="@+id/rg_dr_symptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <RadioButton
                            android:id="@+id/rb_dr_yes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/yes"
                            android:layout_marginEnd="16dp" />

                        <RadioButton
                            android:id="@+id/rb_dr_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_dr_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_alert_ophthalmologist_referral"
                        android:textColor="@color/color_error_text"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:background="@color/color_error_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>

                <!-- Presbyopia -->
                <LinearLayout
                    android:id="@+id/ll_presbyopia_subfield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_presbyopia_symptoms"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <RadioGroup
                        android:id="@+id/rg_presbyopia_symptoms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <RadioButton
                            android:id="@+id/rb_presbyopia_yes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/yes"
                            android:layout_marginEnd="16dp" />

                        <RadioButton
                            android:id="@+id/rb_presbyopia_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_presbyopia_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_alert_presbyopia_management"
                        android:textColor="@color/color_info_text"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:background="@color/color_info_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>

                <!-- Trachoma -->
                <LinearLayout
                    android:id="@+id/ll_trachoma_subfield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_trachoma_status"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_trachoma_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_select_trachoma_status"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tv_trachoma_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_alert_ophthalmologist_referral"
                        android:textColor="@color/color_error_text"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:background="@color/color_error_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>

                <!-- Corneal disease -->
                <LinearLayout
                    android:id="@+id/ll_corneal_subfield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_corneal_disease_type"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_corneal_disease_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_select_corneal_disease_type"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tv_corneal_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_alert_ophthalmologist_referral"
                        android:textColor="@color/color_error_text"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:background="@color/color_error_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>

                <!-- Dry eye / Vitamin A -->
                <LinearLayout
                    android:id="@+id/ll_vitamin_a_subfield"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_vitamin_a_deficiency_label"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <RadioGroup
                        android:id="@+id/rg_vitamin_a_deficiency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <RadioButton
                            android:id="@+id/rb_vitamin_a_yes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/yes"
                            android:layout_marginEnd="16dp" />

                        <RadioButton
                            android:id="@+id/rb_vitamin_a_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_vitamin_a_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_alert_vitamin_a"
                        android:textColor="@color/color_error_text"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:background="@color/color_error_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>

            </LinearLayout>



            <LinearLayout
                android:id="@+id/ll_injury_trauma_module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ophthalmic_injury_trauma_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ophthalmic_injury_type_label"
                    android:textColor="@color/black"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/tv_injury_type_selection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/ophthalmic_select_injury_type"
                        android:inputType="none"
                        android:focusable="true"
                        android:clickable="true" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <Button
                android:id="@+id/btn_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/next"
                android:layout_marginTop="24dp"/>


        </LinearLayout>
    </ScrollView>
</layout>