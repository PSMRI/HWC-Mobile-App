<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="org.piramalswasthya.cho.ui.ophthalmic_screening.OphthalmicScreeningViewModel" />
        <import type="android.view.View"/>
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_patient_information"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_normal"
                android:backgroundTint="?attr/colorPrimary"
                android:elevation="@dimen/padding_normal"
                app:cardCornerRadius="@dimen/padding_normal"
                app:cardElevation="@dimen/padding_normal"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_ben_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="@dimen/padding_normal"
                        android:text="@{viewModel.benName}"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@android:color/white"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/tv_age_gender"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Name" />

                    <TextView
                        android:id="@+id/tv_age_gender"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="@dimen/padding_normal"
                        android:text="@{viewModel.benAgeGender}"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@android:color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:text="36 Years | Male" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/ll_screening_module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ophthalmic_screening_section_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ophthalmic_is_diabetic"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/rg_is_diabetic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/rb_diabetic_yes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/yes"
                        android:onClick="@{() -> viewModel.setDiabeticStatus(true)}"
                        android:checked="@{viewModel.isDiabetic == true}"
                        android:layout_marginEnd="16dp"/>

                    <RadioButton
                        android:id="@+id/rb_diabetic_no"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no"
                        android:onClick="@{() -> viewModel.setDiabeticStatus(false)}"
                        android:checked="@{viewModel.isDiabetic == false}"/>
                </RadioGroup>

                <LinearLayout
                    android:id="@+id/ll_screening_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ophthalmic_screening_performed"
                        android:textColor="#000000"
                        android:layout_marginBottom="8dp"/>

                    <RadioGroup
                        android:id="@+id/rg_screening_performed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <RadioButton
                            android:id="@+id/rb_screening_yes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/yes"
                            android:onClick="@{() -> viewModel.setScreeningPerformed(true)}"
                            android:checked="@{viewModel.isScreeningPerformed == true}"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rb_screening_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no"
                            android:onClick="@{() -> viewModel.setScreeningPerformed(false)}"
                            android:checked="@{viewModel.isScreeningPerformed == false}"/>
                    </RadioGroup>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_chart_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_chart_used"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_chart_used"
                            android:inputType="none"
                            android:text="@{viewModel.chartUsed}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_dist_va_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_dist_va_right"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_dist_va_right"
                            android:inputType="none"
                            android:text="@{viewModel.distVARight}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_dist_va_left"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_dist_va_left"
                            android:inputType="none"
                            android:text="@{viewModel.distVALeft}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_near_va_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_near_va"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ophthalmic_near_va"
                            android:inputType="none"
                            android:text="@{viewModel.nearVA}"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_visual_impairment_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ophthalmic_visual_impairment_alert"
                android:textColor="@color/color_error_text"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="@color/color_error_bg"
                android:visibility="@{viewModel.showVisualImpairmentAlert ? View.VISIBLE : View.GONE}"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ophthalmic_near_vision_alert"
                android:textColor="@color/alert_text_color"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="@color/alert_background"
                android:visibility="@{viewModel.showNearVisionAlert ? View.VISIBLE : View.GONE}"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btn_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/next"
                android:enabled="@{viewModel.canProceed}"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>
</layout>
